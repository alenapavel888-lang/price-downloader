import os
import sqlite3
import pandas as pd
import re

DATA_DIR = "data"
DB_PATH = "index.db"

SUPPLIERS = {
    "equip": "equip.xlsx",
    "bio": "bio.xlsx",
    "rp": "rp.xlsx",
    "rosholod": "rosholod.xlsx",
    "smirnov": "smirnov.xlsx",
    "trade_design": "td.xlsx",
}

BRAND_ALIASES = {
    "electrolux professional": "electrolux",
    "electrolux pro": "electrolux",
    "electrolux": "electrolux",
    "robot coupe": "robotcoupe",
    "robot-coupe": "robotcoupe",
    "abat": "abat",
    "абат": "abat",
}

# -------------------------

def normalize(text):
    return re.sub(r"\s+", " ", re.sub(r"[^\w\s×x]", " ", str(text).lower())).strip()

def normalize_brand(text):
    t = normalize(text)
    for k, v in BRAND_ALIASES.items():
        if k in t:
            return v
    return t.split()[0] if t else ""

def extract_numbers(text):
    res = {}
    patterns = {
        "kg": r"(\d+(?:[.,]\d+)?)\s*кг",
        "liters": r"(\d+(?:[.,]\d+)?)\s*л",
        "levels": r"(\d+)\s*уров",
        "kw": r"(\d+(?:[.,]\d+)?)\s*квт",
    }
    for k, p in patterns.items():
        m = re.search(p, text)
        if m:
            res[k] = float(m.group(1).replace(",", "."))
    return res

# -------------------------

def build_index():
    if os.path.exists(DB_PATH):
        os.remove(DB_PATH)

    conn = sqlite3.connect(DB_PATH)
    cur = conn.cursor()

    cur.execute("""
    CREATE TABLE items (
        id INTEGER PRIMARY KEY,
        supplier TEXT,
        article TEXT,
        name TEXT,
        brand TEXT,
        normalized_text TEXT,
        kg REAL,
        liters REAL,
        levels INTEGER,
        kw REAL,
        dealer_price REAL,
        retail_price REAL,
        availability TEXT,
        source_file TEXT
    )
    """)

    total = 0

    for supplier, file in SUPPLIERS.items():
        path = os.path.join(DATA_DIR, file)
        print(f"📄 Индексация {supplier}: {file}")

        df = pd.read_excel(path, dtype=str).fillna("")

        for _, row in df.iterrows():
            text = normalize(" ".join(map(str, row.values)))
            nums = extract_numbers(text)

            cur.execute("""
            INSERT INTO items (
                supplier, article, name, brand,
                normalized_text, kg, liters, levels, kw,
                dealer_price, retail_price, availability, source_file
            ) VALUES (?,?,?,?,?,?,?,?,?,?,?,?,?)
            """, (
                supplier,
                row.get("Артикул",""),
                row.get("Наименование",""),
                normalize_brand(row.get("Наименование","")),
                text,
                nums.get("kg"),
                nums.get("liters"),
                nums.get("levels"),
                nums.get("kw"),
                row.get("Цена дилерская"),
                row.get("Цена розничная"),
                row.get("Наличие"),
                file
            ))

            total += 1

    conn.commit()
    conn.close()

    print(f"✅ index.db пересобран. Записей: {total}")

# -------------------------

if __name__ == "__main__":
    build_index()

